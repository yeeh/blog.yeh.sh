---
import { tagUrl } from '../lib/content.js';
const { pagination } = Astro.props;
---
<div class="archive-list">
{pagination.posts.map((post) => (
  <article class="archive-item" role="article">
    <time class="archive-date" datetime={post.dateXml}>{post.displayDate}</time>
    <div>
      <h2 class="archive-title"><a href={post.url}>{post.title}</a></h2>
      <p class="archive-summary">{post.summary}</p>
      {post.tags.length > 0 && (
      <div class="archive-meta">
        {post.tags.map((tag) => <a href={tagUrl(tag)} rel="tag">#{tag}</a>)}
      </div>
      )}
    </div>
  </article>
))}
</div>
<footer class="pagination" role="navigation">
<span>{pagination.page}/{pagination.totalPages}</span>
{pagination.previousPage && (
  pagination.previousPage === 1 ? <a href="/" title="First">&lt;</a> : <><a href="/" title="First">&lt;&lt;</a><a href={pagination.previousPagePath} title="Prev">&lt;</a></>
)}
{Array.from({ length: Math.min(3, pagination.totalPages - pagination.page + 1) }, (_, i) => pagination.page + i).map((count) => (
  count === pagination.page ? <span>{count}</span> : <a href={`/page/${count}/`}>{count}</a>
))}
{pagination.nextPage && (
  pagination.nextPage === pagination.totalPages ? <a href={pagination.nextPagePath} title="Last">&gt;</a> : <><a href={pagination.nextPagePath} title="Next">&gt;</a><a href={`/page/${pagination.totalPages}/`} title="Last">&gt;&gt;</a></>
)}
</footer>
